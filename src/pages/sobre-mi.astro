---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
// Importamos el tercer componente interactivo de React para cumplir con la UI Library
import AcordeonInfo from '../components/AcordeonInfo.jsx';
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Sobre Mí - Oriana Cappelli</title>
    <link rel="icon" type="image/png" href="/logo-mio.png" />
  </head>
  <body class="bg-[#f4ebf2] font-sans flex flex-col min-h-screen">
    <Navbar />
    
    <!-- foto a la izquierda y biografia a la derecha -->
    <main class="flex-grow w-full max-w-6xl mx-auto px-6 py-16 md:py-24 flex flex-col md:flex-row gap-16 md:gap-24 items-center md:items-start">
      
      <!-- izquierda -->
      <div class="w-full md:w-[380px] shrink-0 flex flex-col items-center">
        
        <!-- contenedor de la foto  -->
        <div class="w-full bg-white border-[3px] border-black p-3 shadow-[8px_8px_0px_0px_rgba(0,0,0,1)]">
          <div class="w-full aspect-[4/5] bg-zinc-200 border-[3px] border-black overflow-hidden">
            <img src="/foto-perfil.jpg" alt="Oriana Cappelli" class="w-full h-full object-cover" />
          </div>
          <div class="p-4 text-center bg-white">
            <p class="text-3xl font-black text-black uppercase tracking-tight">
              Hola! Soy Ori
            </p>
          </div>
        </div>

        <!-- boton a la pagina de contacto -->
        <a href="/contacto" class="group block w-full bg-[#8b5cf6] border-[3px] border-black p-5 mt-8 text-center hover:-translate-y-1 hover:shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] transition-all duration-200 cursor-pointer">
          <span class="text-2xl font-black text-white uppercase tracking-tight">Contáctame</span>
        </a>

      </div>

      <!-- derecha -->
      <div class="w-full flex flex-col text-black pt-4">
        <h1 class="text-5xl md:text-6xl font-black uppercase tracking-tight text-black leading-none mb-8">
          Sobre Mí
        </h1>
        <p class="text-xl md:text-[22px] leading-relaxed font-medium text-gray-900 mb-10">
          Hola, soy Oriana Cappelli, tengo 23 años y soy de Argentina.<br/>
          Me gusta pensar y estructurar visualmente experiencias digitales, enfocándome en crear interfaces estéticas, intuitivas y centradas en el usuario.<br/>
          Mi objetivo es traducir ideas y conceptos en diseños limpios y atractivos que realmente conecten con las personas.
        </p>

        <!-- linea divisoria  -->
        <hr class="border-t-[3px] border-black mb-10" />

        <!-- seccion de habilidades (skills) con los logos  -->
        <h2 class="text-3xl md:text-4xl font-black uppercase tracking-tight mb-6">Skills</h2>
        
        <div class="flex flex-wrap gap-4 mb-10">
          <div class="bg-white border-[3px] border-black p-3 shadow-[4px_4px_0px_0px_rgba(0,0,0,1)]">
            <img src="/logo-figma.png" alt="Figma" class="w-16 h-16 object-cover" />
          </div>
          <div class="bg-white border-[3px] border-black p-3 shadow-[4px_4px_0px_0px_rgba(0,0,0,1)]">
            <img src="/logo-ai.png" alt="Illustrator" class="w-16 h-16 object-cover" />
          </div>
          <div class="bg-white border-[3px] border-black p-3 shadow-[4px_4px_0px_0px_rgba(0,0,0,1)]">
            <img src="/logo-ps.png" alt="Photoshop" class="w-16 h-16 object-cover" />
          </div>
          <div class="bg-white border-[3px] border-black p-3 shadow-[4px_4px_0px_0px_rgba(0,0,0,1)]">
            <img src="/logo-ae.png" alt="After Effects" class="w-16 h-16 object-cover" />
          </div>
        </div>

        <!-- divisor -->
        <hr class="border-t-[3px] border-black mb-10" />

        <!-- educacion  -->
        <h2 class="text-3xl md:text-4xl font-black uppercase tracking-tight mb-4">Educación</h2>
        <div class="bg-white border-[3px] border-black p-6 shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] mb-10">
          <p class="text-xl md:text-2xl font-black text-black uppercase tracking-tight mb-1">
            Tecnología Multimedial
          </p>
          <p class="text-lg font-medium text-gray-800">
            Universidad Maimónides
          </p>
        </div>

        <!-- divisor -->
        <hr class="border-t-[3px] border-black mb-10" />

        <!-- seccion del acordeon interactivo importado desde el componente de react -->
        <h2 class="text-3xl md:text-4xl font-black uppercase tracking-tight mb-6">Más sobre mí</h2>
        <div class="w-full">
          <AcordeonInfo client:load />
        </div>

      </div>

    </main>

    <Footer />
  </body>
</html>