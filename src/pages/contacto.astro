---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import BotonCopiarEmail from '../components/BotonCopiarEmail.jsx';
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Contacto - Oriana Cappelli</title>
    <link rel="icon" type="image/png" href="/logo-mio.png" />
  </head>
  <body class="bg-[#f4ebf2] font-sans flex flex-col min-h-screen">
    <Navbar />
    
    <!-- seccion principal  -->
    <main class="flex-grow w-full max-w-6xl mx-auto px-6 py-16 md:py-24 flex flex-col md:flex-row gap-16 md:gap-24">
      
      <!-- izq Formulario -->
      <div class="w-full md:w-1/2 flex flex-col">
        <h1 class="text-6xl md:text-[80px] font-black uppercase tracking-tight text-black leading-none mb-8">
          ¡Hablemos!
        </h1>
        
        <!-- formulario configurado para enviar datos mediante formspree de forma dinamica -->
        <form id="contact-form" action="https://formspree.io/f/mojgkvgl" method="POST" class="flex flex-col gap-6">
          
          <div class="flex flex-col">
            <label for="name" class="font-bold text-black uppercase tracking-wider mb-2 text-sm md:text-base">Tu Nombre</label>
            <input type="text" id="name" name="name" required placeholder="Ej: Juan Pérez" 
                   class="w-full bg-white border-[3px] border-black p-4 rounded-none font-medium text-lg text-black focus:bg-[#e9d5e5] focus:outline-none transition-colors" />
          </div>

          <div class="flex flex-col">
            <label for="email" class="font-bold text-black uppercase tracking-wider mb-2 text-sm md:text-base">Tu Email</label>
            <input type="email" id="email" name="email" required placeholder="ejemplo@correo.com" 
                   class="w-full bg-white border-[3px] border-black p-4 rounded-none font-medium text-lg text-black focus:bg-[#e9d5e5] focus:outline-none transition-colors" />
          </div>

          <div class="flex flex-col">
            <label for="message" class="font-bold text-black uppercase tracking-wider mb-2 text-sm md:text-base">Mensaje</label>
            <textarea id="message" name="message" required rows="4" placeholder="Contame sobre tu proyecto..." 
                      class="w-full bg-white border-[3px] border-black p-4 rounded-none font-medium text-lg text-black resize-none focus:bg-[#e9d5e5] focus:outline-none transition-colors"></textarea>
          </div>

          <button type="submit" class="group block w-full bg-[#1ea04c] border-[3px] border-black p-5 mt-2 hover:-translate-y-1 hover:shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] transition-all duration-200 cursor-pointer">
            <span class="text-2xl font-black text-white uppercase tracking-tight">Enviar Mensaje</span>
          </button>
        </form>

        <!-- cartel de exito que se muestra oculto hasta que el formulario se envia correctamente -->
        <div id="success-message" class="hidden bg-[#1ea04c] border-[3px] border-black p-8 mt-4 shadow-[8px_8px_0px_0px_rgba(0,0,0,1)]">
          <h3 class="text-3xl font-black text-white uppercase tracking-tight mb-2">¡Mensaje enviado!</h3>
          <p class="text-lg font-medium text-white">Gracias por escribirme. Me voy a poner en contacto con vos muy pronto.</p>
        </div>

      </div>

      <!-- der botones de redes -->
      <div class="w-full md:w-1/2 flex flex-col gap-6 justify-center">
        
        <!-- componente de react para copiar el mail al portapapeles -->
        <div class="w-full">
          <BotonCopiarEmail client:load />
        </div>

        <!-- boton de enlace a mi linkedin -->
        <a href="https://www.linkedin.com/in/oriana-cappelli-16ab7b255/" target="_blank" class="group block w-full bg-white border-[3px] border-black p-6 md:p-8 hover:-translate-y-1 hover:shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] transition-all duration-200">
          <div class="flex justify-between items-center">
            <span class="text-3xl md:text-4xl font-black text-black uppercase tracking-tight">LinkedIn</span>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-black" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
              <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </div>
        </a>

        <!-- boton de enlace a instagram -->
        <a href="https://www.instagram.com/" target="_blank" class="group block w-full bg-white border-[3px] border-black p-6 md:p-8 hover:-translate-y-1 hover:shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] transition-all duration-200">
          <div class="flex justify-between items-center">
            <span class="text-3xl md:text-4xl font-black text-black uppercase tracking-tight">Instagram</span>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-black" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
              <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </div>
        </a>

      </div>

    </main>

    <Footer />

    <!-- script de javascript para manejar el envio asincronico del formulario sin recargar la pagina -->
    <script is:inline>
      // creo una funcion para englobar toda la logica del formulario de contacto
      const configurarFormulario = () => {
        // busco en el html el formulario y el cartel de exito por sus ids
        const form = document.getElementById('contact-form');
        const successMessage = document.getElementById('success-message');

        // me aseguro de que el formulario exista en la pagina antes de agregarle el evento
        if (form) {
          // intercepto el evento submit para evitar que la pagina se recargue sola al enviar
          form.onsubmit = async function(e) {
            e.preventDefault();
            // armo un objeto con todos los datos que escribio el usuario en los campos
            const data = new FormData(form);
            
            try {
              // hago un fetch para mandar los datos por atras a formspree sin cambiar de pantalla
              const response = await fetch(form.action, {
                method: form.method,
                body: data,
                headers: { 'Accept': 'application/json' }
              });
              
              // si el servidor me devuelve una respuesta ok, oculto el form y muestro el cartel de exito
              if (response.ok) {
                form.style.display = 'none';
                if (successMessage) successMessage.classList.remove('hidden');
              } else {
                alert('Hubo un error al enviar el mensaje. Por favor, intentá de nuevo.');
              }
            } catch (error) {
              // si hay algun problema de conexion salta esta alerta de error
              alert('Hubo un error de conexión. Por favor, intentá de nuevo.');
            }
          };
        }
      };

      // ejecuto la funcion de entrada y tambien la engancho al evento de astro por si navego entre secciones
      configurarFormulario();
      document.addEventListener('astro:page-load', configurarFormulario);
    </script>
  </body>
</html>