---
// src/components/Proyectos.astro
---

<section id="proyectos" class="w-full max-w-6xl mx-auto px-6 py-24">
   <!-- titulo -->
  <div class="flex items-center mb-12">
    <a href="/proyectos" class="inline-flex items-center gap-4 text-4xl md:text-5xl font-black text-black tracking-tight hover:opacity-70 transition-opacity group">
      <span>Algunos de mis proyectos</span>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 md:h-10 md:w-10 text-black stroke-[4px] translate-y-1 md:translate-y-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
      </svg>
    </a>
  </div>

  <!-- contenedor horizontal -->
  <div class="flex overflow-x-auto gap-8 p-20 snap-x snap-mandatory [scrollbar-width:none] [-ms-overflow-style:none] [&::-webkit-scrollbar]:hidden">
    
    <!-- TARJETA 1 -->
    <div class="shrink-0 w-[85vw] md:w-[600px] snap-center">
      <a href="/proyectos/7up" class="block w-full h-full group">
        <div class="w-full h-full bg-white border-[3px] border-black rounded-none shadow-xl group-hover:scale-[1.01] transition-transform duration-300 flex flex-col">
          <figure class="w-full h-64 md:h-[350px] bg-[#1ea04c] border-b-[3px] border-black overflow-hidden">
            <img src="/proyecto-7up.png" alt="Publicidad 7up" class="w-full h-full object-cover" />
          </figure>
          <div class="p-6 md:p-8 flex justify-center items-center bg-white flex-grow">
            <h3 class="text-xl md:text-3xl font-black text-black m-0 text-center tracking-tight">Publicidad 7up</h3>
          </div>
        </div>
      </a>
    </div>

    <!-- TARJETA 2 -->
    <div class="shrink-0 w-[85vw] md:w-[600px] snap-center">
      <a href="/proyectos/diseno-beatrix" class="block w-full h-full group">
        <div class="w-full h-full bg-white border-[3px] border-black rounded-none shadow-xl group-hover:scale-[1.01] transition-transform duration-300 flex flex-col">
          <figure class="w-full h-64 md:h-[350px] bg-[#1ea04c] border-b-[3px] border-black overflow-hidden">
            <img src="/portada-beatrix.png" alt="Proyecto Dos" class="w-full h-full object-cover" />
          </figure>
          <div class="p-6 md:p-8 flex justify-center items-center bg-white flex-grow">
            <h3 class="text-xl md:text-3xl font-black text-black m-0 text-center tracking-tight">Concept Art: Beatrix</h3>
          </div>
        </div>
      </a>
    </div>

    <!-- TARJETA 3 -->
    <div class="shrink-0 w-[85vw] md:w-[600px] snap-center">
      <a href="/proyectos/logo-animado" class="block w-full h-full group">
        <div class="w-full h-full bg-white border-[3px] border-black rounded-none shadow-xl group-hover:scale-[1.01] transition-transform duration-300 flex flex-col">
          <figure class="w-full h-64 md:h-[350px] bg-[#1ea04c] border-b-[3px] border-black overflow-hidden">
            <img src="/portada-disney.png" alt="Proyecto Tres" class="w-full h-full object-cover" />
          </figure>
          <div class="p-6 md:p-8 flex justify-center items-center bg-white flex-grow">
            <h3 class="text-xl md:text-3xl font-black text-black m-0 text-center tracking-tight">Logo Animado: Disney Channel</h3>
          </div>
        </div>
      </a>
    </div>

    

  </div>
</section>