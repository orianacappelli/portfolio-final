---
// src/components/Proyectos.astro
---

<section id="proyectos" class="w-full max-w-6xl mx-auto px-6 py-24">
  <!-- Título de la sección -->
  <div class="flex items-center gap-4 mb-12">
    <h2 class="text-4xl md:text-5xl font-black text-black tracking-tight">
      Algunos de mis proyectos
    </h2>
    <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 md:h-10 md:w-10 text-black stroke-[4px]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
    </svg>
  </div>

  <!-- Contenedor del Slider Horizontal -->
  <!-- Acá está la magia: agregamos 'py-8' para darle espacio arriba y abajo al efecto hover -->
  <div class="flex overflow-x-auto gap-8 p-20 snap-x snap-mandatory [scrollbar-width:none] [-ms-overflow-style:none] [&::-webkit-scrollbar]:hidden">
    
    <!-- TARJETA 1 -->
    <div class="card shrink-0 w-[85vw] md:w-[500px] bg-white rounded-[2rem] overflow-hidden shadow-xl hover:scale-[1.01] transition-transform duration-300 snap-center">
      <figure class="w-full h-64 md:h-[350px] bg-[#1ea04c]">
        <img src="/proyecto-7up.png" alt="Publicidad 7up" class="w-full h-full object-cover" />
      </figure>
      <div class="card-body p-6 md:p-8 flex flex-row justify-between items-center bg-white">
        <h3 class="text-xl md:text-3xl font-black text-black m-0">Publicidad 7up</h3>
        <a href="#" class="btn bg-[#7e57c2] hover:bg-[#65459b] text-white rounded-full px-6 md:px-8 border-none font-bold text-base md:text-lg tracking-wide">
          Ver más
        </a>
      </div>
    </div>

    <!-- TARJETA 2 -->
    <div class="card shrink-0 w-[85vw] md:w-[500px] bg-white rounded-[2rem] overflow-hidden shadow-xl hover:scale-[1.01] transition-transform duration-300 snap-center">
      <figure class="w-full h-64 md:h-[350px] bg-[#1ea04c]">
        <img src="/proyecto-7up.png" alt="Proyecto 2" class="w-full h-full object-cover" />
      </figure>
      <div class="card-body p-6 md:p-8 flex flex-row justify-between items-center bg-white">
        <h3 class="text-xl md:text-3xl font-black text-black m-0">Proyecto Dos</h3>
        <a href="#" class="btn bg-[#7e57c2] hover:bg-[#65459b] text-white rounded-full px-6 md:px-8 border-none font-bold text-base md:text-lg tracking-wide">
          Ver más
        </a>
      </div>
    </div>

    <!-- TARJETA 3 -->
    <div class="card shrink-0 w-[85vw] md:w-[500px] bg-white rounded-[2rem] overflow-hidden shadow-xl hover:scale-[1.01] transition-transform duration-300 snap-center">
      <figure class="w-full h-64 md:h-[350px] bg-[#1ea04c]">
        <img src="/proyecto-7up.png" alt="Proyecto 3" class="w-full h-full object-cover" />
      </figure>
      <div class="card-body p-6 md:p-8 flex flex-row justify-between items-center bg-white">
        <h3 class="text-xl md:text-3xl font-black text-black m-0">Proyecto Tres</h3>
        <a href="#" class="btn bg-[#7e57c2] hover:bg-[#65459b] text-white rounded-full px-6 md:px-8 border-none font-bold text-base md:text-lg tracking-wide">
          Ver más
        </a>
      </div>
    </div>

    <!-- TARJETA 4 -->
    <div class="card shrink-0 w-[85vw] md:w-[500px] bg-white rounded-[2rem] overflow-hidden shadow-xl hover:scale-[1.01] transition-transform duration-300 snap-center">
      <figure class="w-full h-64 md:h-[350px] bg-[#1ea04c]">
        <img src="/proyecto-7up.png" alt="Proyecto 4" class="w-full h-full object-cover" />
      </figure>
      <div class="card-body p-6 md:p-8 flex flex-row justify-between items-center bg-white">
        <h3 class="text-xl md:text-3xl font-black text-black m-0">Proyecto Cuatro</h3>
        <a href="#" class="btn bg-[#7e57c2] hover:bg-[#65459b] text-white rounded-full px-6 md:px-8 border-none font-bold text-base md:text-lg tracking-wide">
          Ver más
        </a>
      </div>
    </div>

  </div>
</section>