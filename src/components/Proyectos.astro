---
// src/components/Proyectos.astro
---

<!-- seccion que tiene los proyectos -->
<section id="proyectos" class="w-full max-w-6xl mx-auto px-6 py-16 md:py-24 overflow-hidden">
   <!-- titulo de la seccion con un enlace  -->
  <div class="flex items-center mb-8 md:mb-12">
    <a href="/proyectos" class="inline-flex items-center gap-3 md:gap-4 text-3xl sm:text-4xl md:text-5xl font-black text-black tracking-tight hover:opacity-70 transition-opacity group">
      <span>Algunos de mis proyectos</span>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 md:h-10 md:w-10 text-black stroke-[4px] translate-y-0.5 md:translate-y-1.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
      </svg>
    </a>
  </div>

  <!-- contenedor horizontal con scroll  -->
  <div class="flex overflow-x-auto gap-6 md:gap-8 px-2 py-6 md:p-20 snap-x snap-mandatory [scrollbar-width:none] [-ms-overflow-style:none] [&::-webkit-scrollbar]:hidden">
    
    <!-- TARJETA 1 -->
    <div class="shrink-0 w-[85vw] sm:w-[400px] md:w-[600px] snap-center tarjeta-gsap">
      <a href="/proyectos/7up" class="block w-full h-full group">
        <div class="w-full h-full bg-white border-[3px] border-black rounded-none shadow-[6px_6px_0px_0px_rgba(0,0,0,1)] md:shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] group-hover:scale-[1.01] transition-transform duration-300 flex flex-col">
          <figure class="w-full h-56 sm:h-72 md:h-[350px] bg-[#1ea04c] border-b-[3px] border-black overflow-hidden">
            <img src="/proyecto-7up.png" alt="Publicidad 7up" class="w-full h-full object-cover" />
          </figure>
          <div class="p-5 md:p-8 flex justify-center items-center bg-white flex-grow">
            <h3 class="text-xl sm:text-2xl md:text-3xl font-black text-black m-0 text-center tracking-tight">Publicidad 7up</h3>
          </div>
        </div>
      </a>
    </div>

    <!-- TARJETA 2 -->
    <div class="shrink-0 w-[85vw] sm:w-[400px] md:w-[600px] snap-center tarjeta-gsap">
      <a href="/proyectos/diseno-beatrix" class="block w-full h-full group">
        <div class="w-full h-full bg-white border-[3px] border-black rounded-none shadow-[6px_6px_0px_0px_rgba(0,0,0,1)] md:shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] group-hover:scale-[1.01] transition-transform duration-300 flex flex-col">
          <figure class="w-full h-56 sm:h-72 md:h-[350px] bg-[#1ea04c] border-b-[3px] border-black overflow-hidden">
            <img src="/portada-beatrix.png" alt="Concept Art: Beatrix" class="w-full h-full object-cover" />
          </figure>
          <div class="p-5 md:p-8 flex justify-center items-center bg-white flex-grow">
            <h3 class="text-xl sm:text-2xl md:text-3xl font-black text-black m-0 text-center tracking-tight">Concept Art: Beatrix</h3>
          </div>
        </div>
      </a>
    </div>

    <!-- TARJETA 3 -->
    <div class="shrink-0 w-[85vw] sm:w-[400px] md:w-[600px] snap-center tarjeta-gsap">
      <a href="/proyectos/logo-animado" class="block w-full h-full group">
        <div class="w-full h-full bg-white border-[3px] border-black rounded-none shadow-[6px_6px_0px_0px_rgba(0,0,0,1)] md:shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] group-hover:scale-[1.01] transition-transform duration-300 flex flex-col">
          <figure class="w-full h-56 sm:h-72 md:h-[350px] bg-[#1ea04c] border-b-[3px] border-black overflow-hidden">
            <img src="/portada-disney.png" alt="Logo Animado: Disney Channel" class="w-full h-full object-cover" />
          </figure>
          <div class="p-5 md:p-8 flex justify-center items-center bg-white flex-grow">
            <h3 class="text-xl sm:text-2xl md:text-3xl font-black text-black m-0 text-center tracking-tight">Logo Animado: Disney Channel</h3>
          </div>
        </div>
      </a>
    </div>

  </div>
</section>

<!-- cdn de gsap con una animacion mucho mas vistosa de entrada -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
<script is:inline>
  const animarProyectosDramatico = () => {
    if (typeof gsap !== 'undefined') {
      gsap.from(".tarjeta-gsap", {
        scale: 0.6,          // arrancan achicadas al 60%
        opacity: 0,          // desde totalmente invisibles
        y: 80,               // suben desde mas abajo
        duration: 1,         // un segundo de animacion
        stagger: 0.3,        // una se despliega despues de la otra
        ease: "back.out(1.7)" // efecto elastico de rebote al finalizar
      });
    }
  };

  window.addEventListener('DOMContentLoaded', animarProyectosDramatico);
  document.addEventListener('astro:page-load', animarProyectosDramatico);
</script>