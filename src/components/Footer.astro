---
// src/components/Footer.astro
---

<!-- armo el footer general en dos mitades con flexbox para que sea responsive -->
<footer id="contacto" class="w-full bg-white border-t-[3px] border-black flex flex-col md:flex-row mt-12">
  
  <!-- mitad izquierda el LOGO -->
  <!-- en esta mitad izquierda pongo el logo con bordes fuertes y diseno adaptable -->
  <div class="w-full md:w-1/2 flex justify-center items-center p-10 sm:p-16 md:p-24 border-b-[3px] md:border-b-0 md:border-r-[3px] border-black">
    <h2 class="text-5xl sm:text-6xl md:text-8xl font-black tracking-tighter text-black uppercase">
      logo
    </h2>
  </div>

  <!-- mitad derecha para las redes -->
  <!-- en la mitad derecha armo una columna para agrupar los botones de mis redes -->
  <div class="w-full md:w-1/2 flex flex-col">
    
    <!-- ig -->
    <a href="https://www.instagram.com/" target="_blank" rel="noopener noreferrer" class="flex-1 flex items-center justify-center gap-3 sm:gap-4 p-6 sm:p-8 md:p-10 border-b-[3px] border-black hover:bg-black hover:text-white transition-colors text-black group">
      <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0">
        <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
        <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
        <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
      </svg>
      <span class="font-bold text-xl sm:text-2xl lowercase tracking-wide">instagram</span>
    </a>

    <!-- linkedin -->
    <a href="https://www.linkedin.com/in/oriana-cappelli-16ab7b255/" target="_blank" rel="noopener noreferrer" class="flex-1 flex items-center justify-center gap-3 sm:gap-4 p-6 sm:p-8 md:p-10 border-b-[3px] border-black hover:bg-black hover:text-white transition-colors text-black group">
      <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0">
        <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path>
        <rect x="2" y="9" width="4" height="12"></rect>
        <circle cx="4" cy="4" r="2"></circle>
      </svg>
      <span class="font-bold text-xl sm:text-2xl lowercase tracking-wide">linkedin</span>
    </a>

    <a href="https://mail.google.com/mail/?view=cm&fs=1&to=orianacappelli1@gmail.com" target="_blank" rel="noopener noreferrer" class="flex-1 flex items-center justify-center gap-3 sm:gap-4 p-6 sm:p-8 md:p-10 hover:bg-black hover:text-white transition-colors text-black group">
      <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="shrink-0">
        <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
        <polyline points="22,6 12,13 2,6"></polyline>
      </svg>
      <span class="font-bold text-xl sm:text-2xl lowercase tracking-wide">email</span>
    </a>

  </div>
</footer>